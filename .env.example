# Copy to `.env` (gitignored) — loaded at server startup; real env wins.
#
# Provider keys (any one unlocks that provider in the picker):
#   ANTHROPIC_API_KEY=...
#   OPENAI_API_KEY=...
#   OPENROUTER_API_KEY=...
#   GOOGLE_API_KEY=...
#   OLLAMA_HOST=http://127.0.0.1:11434
#
# Default model spec — "provider:model", bare "provider" (its default
# model), or "dummy" (the scripted test model):
#   NONTAINER_STUDIO_MODEL=openrouter
#   NONTAINER_STUDIO_MODEL=openrouter:deepseek/deepseek-v4-flash
#
# Other knobs:
#   NONTAINER_STUDIO_PORT=8321
#   NONTAINER_STUDIO_STORE=~/.nontainer-studio
#   NONTAINER_STUDIO_CSP=none
